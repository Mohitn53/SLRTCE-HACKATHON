# Environment Configuration Template

## Copy this file as `.env` and fill in your values
## Never commit .env file - it contains sensitive information

# ============================================================================
# OpenWeatherMap API Configuration
# ============================================================================

# Get your free API key from: https://openweathermap.org/api
# Free tier includes: Current weather, Forecasts, Air pollution data
OPENWEATHER_API_KEY=

# ============================================================================
# Flask API Configuration
# ============================================================================

# Environment: development, staging, production
FLASK_ENV=development

# Enable/disable debug mode
FLASK_DEBUG=True

# Port for Flask API
FLASK_PORT=5000

# ============================================================================
# Database Configuration (Optional - for future enhancement)
# ============================================================================

# DATABASE_URL=mongodb://username:password@localhost:27017/kisan_setu

# ============================================================================
# Streamlit Configuration (Optional)
# ============================================================================

# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_HEADLESS=false

# ============================================================================
# Logging Configuration (Optional)
# ============================================================================

# LOG_LEVEL=INFO
# LOG_FILE=logs/kisan_setu.log

# ============================================================================
# Data Configuration
# ============================================================================

# Path to HDF5 model file
MODEL_FILE=Reduced_SMAP_L4_SM_aup.h5

# Maximum records to process at once (for memory efficiency)
MAX_RECORDS_BATCH=1000

# ============================================================================
# Feature Flags
# ============================================================================

# Enable weather API integration
ENABLE_WEATHER=True

# Enable simulation engine
ENABLE_SIMULATION=True

# Enable API server
ENABLE_API=True

# Enable dashboard
ENABLE_DASHBOARD=True

# ============================================================================
# Simulation Parameters
# ============================================================================

# Default irrigation rate (0-1 scale)
IRRIGATION_RATE=0.05

# Default evaporation rate (0-1 scale)
EVAPORATION_RATE=0.01

# Default forecast days
DEFAULT_FORECAST_DAYS=3

# ============================================================================
# Thresholds
# ============================================================================

# Soil moisture thresholds
DRY_THRESHOLD=0.15
MODERATE_THRESHOLD=0.22

# Rainfall threshold for skipping irrigation (mm)
RAIN_SKIP_THRESHOLD=5.0

# ============================================================================
# Security (Production Only)
# ============================================================================

# API Secret Key
# SECRET_KEY=your-secret-key-here-change-in-production

# CORS Allowed Origins
# CORS_ORIGINS=https://example.com,https://app.example.com

# Rate limiting
# RATE_LIMIT_ENABLED=True
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_PERIOD=3600

# ============================================================================
# Notes
# ============================================================================
#
# 1. Never share or commit the .env file
# 2. Use strong, unique API keys in production
# 3. Keep credentials secure and rotate regularly
# 4. Use environment-specific configurations for dev/staging/production
# 5. For sensitive data, prefer using:
#    - Environment variables (recommended)
#    - AWS Secrets Manager
#    - HashiCorp Vault
#    - Other secret management tools
#
